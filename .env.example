# Сервер
SERVER_PORT=8080
APP_ENV=development

# База данных (DSN — единая строка подключения)
DB_DSN=host=localhost user=synergy_user password=synergy_password dbname=synergy_db port=5432 sslmode=disable

# Redis (пока не используется, но оставляем для будущих шагов)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (внимание: секрет должен быть длинным и сложным!)
JWT_SECRET=your-super-secret-key-change-in-production-at-least-32-characters
JWT_ACCESS_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=720h

# Email (для напоминаний) — будет использоваться в Шаге 2 (Спринт 2)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com

# Argon2id параметры (безопасные значения по умолчанию)
ARGON_TIME=3
ARGON_MEMORY=65536
ARGON_THREADS=4
ARGON_KEY_LENGTH=32