# Сервер
SERVER_PORT=8080
APP_ENV=development

# База данных
DB_HOST=localhost
DB_PORT=5432
DB_USER=synergy_user
DB_PASSWORD=synergy_password
DB_NAME=synergy_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-change-me-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_HOURS=720

# Email (для напоминаний)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com

# Безопасность
ARGON_TIME=3
ARGON_MEMORY=65536
ARGON_THREADS=4
ARGON_KEY_LENGTH=32